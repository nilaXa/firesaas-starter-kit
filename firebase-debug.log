[debug] [2026-06-01T08:54:09.049Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-fire-saas:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper functions\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function getUid() {\n      return isAuthenticated() ? request.auth.uid : 'anonymous';\n    }\n\n    function isOwner(userId) {\n      return isAuthenticated() && request.auth.uid == userId;\n    }\n\n    // Checks if the user is a member of the given organization\n    function isOrgMember(orgId) {\n      return isAuthenticated() && \n        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(getUid()));\n    }\n\n    // Gets the member record for the current user in an organization\n    function getOrgMember(orgId) {\n      return get(/databases/$(database)/documents/organizations/$(orgId)/members/$(getUid())).data;\n    }\n\n    // Checks if the member has one of the specified roles\n    function hasRole(orgId, roles) {\n      return isOrgMember(orgId) && getOrgMember(orgId).role in roles;\n    }\n\n    // --- Users Profiles Rules ---\n    match /users/{userId} {\n      allow read: if isAuthenticated(); // Allowed for collaboration/member lookups\n      allow write: if isOwner(userId);\n    }\n\n    match /privateUsers/{userId} {\n      allow read: if isOwner(userId);\n      allow write: if false; // Only manageable server-side via Admin SDK\n    }\n\n    // --- Organizations Rules ---\n    match /organizations/{orgId} {\n      // Members can read organization info individually\n      allow get: if isOrgMember(orgId);\n      // Disable global list to prevent tenant directory leaks\n      allow list: if false;\n      \n      // Creating a new organization: allowed if authenticated and setting themselves as the owner\n      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;\n      \n      // Update: only owners and admins\n      allow update: if hasRole(orgId, ['owner', 'admin']);\n      \n      // Deleting organization: only owner\n      allow delete: if hasRole(orgId, ['owner']);\n\n      // --- Members subcollection ---\n      match /members/{userId} {\n        // Members can list other members\n        allow read: if isOrgMember(orgId);\n        \n        // Members can be added:\n        // 1. By owners/admins of the organization\n        // 2. Or if creating the first owner member (during org creation, where ownerId matches userId)\n        allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.role == 'owner') ||\n                       hasRole(orgId, ['owner', 'admin']);\n                       \n        // Updates: only owners and admins. Normal members cannot change roles.\n        // A user cannot change their own role to bypass permissions.\n        allow update: if hasRole(orgId, ['owner', 'admin']) && \n                       (request.auth.uid != userId || getOrgMember(orgId).role == 'owner');\n                       \n        // Delete: only owners/admins can remove members. Members can leave.\n        allow delete: if hasRole(orgId, ['owner', 'admin']) || isOwner(userId);\n      }\n\n      // --- Invitations subcollection ---\n      match /invitations/{inviteId} {\n        allow read: if isAuthenticated(); // To accept invitations, user needs to read it\n        allow create, update, delete: if hasRole(orgId, ['owner', 'admin']);\n      }\n\n      // --- File Metadata Rules ---\n      match /files/{fileId} {\n        allow read: if isOrgMember(orgId);\n        \n        // Only owners, admins, and members can upload files\n        allow create: if hasRole(orgId, ['owner', 'admin', 'member']) && \n                        request.resource.data.ownerId == request.auth.uid;\n                        \n        allow update: if hasRole(orgId, ['owner', 'admin', 'member']);\n        \n        // Deletion: only owners or admins (or the file owner)\n        allow delete: if hasRole(orgId, ['owner', 'admin']) || \n                        resource.data.ownerId == request.auth.uid;\n      }\n\n      // --- AI Usage Logging Rules ---\n      match /aiUsage/{usageId} {\n        allow read: if isOrgMember(orgId);\n        allow write: if false; // Append-only from secure Server Actions / Admin SDK\n      }\n\n      // --- Audit Log Rules ---\n      match /auditLogs/{logId} {\n        allow read: if isOrgMember(orgId);\n        allow write: if false; // Append-only from secure Server Actions / Admin SDK\n      }\n    }\n\n    // Secure collection group rule to allow members to list their own organization links\n    match /{path=**}/members/{memberId} {\n      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || memberId == request.auth.uid);\n    }\n  }\n}\n"}]}}
