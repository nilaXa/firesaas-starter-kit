# App Details
NEXT_PUBLIC_APP_NAME="FireSaaS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Firebase Client SDK Configuration (For Client-Side Authentication)
# Obtain these from your Firebase Console (Project Settings > General > Web Apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK Configuration (For Server-Side Authentication & Actions)
# Required for production deployments.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# In local development, the private key can be left empty if using the emulator suite.
# Keep the private key wrapped in quotes and replace literal newlines with \n.
FIREBASE_PRIVATE_KEY=

# System Admins configuration (comma-separated list of emails)
ADMIN_EMAILS=

# Genkit AI Configuration
GENKIT_ENV="dev"
# Get your API key from Google AI Studio: https://aistudio.google.com/
GOOGLE_GENAI_API_KEY=
AI_TEXT_MODEL="googleai/gemini-3.5-flash"
AI_REASONING_MODEL="googleai/gemini-3.5-flash"
AI_EMBEDDING_MODEL="googleai/gemini-embedding-2"

# Stripe Billing Configuration (Optional Placeholders)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
